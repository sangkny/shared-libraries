# ============================================================
# shared-libraries/llm/.env.example
# 실제 사용 시 .env 로 복사 후 값 입력
# .env 는 절대 Git에 커밋하지 마세요! (.gitignore에 추가)
# ============================================================

# ── Provider 선택 ────────────────────────────────────────
# local | openai | anthropic | google | azure
LLM_PROVIDER=local

# 임베딩 전용 Provider (미설정 시 LLM_PROVIDER와 동일)
# Anthropic 사용 시 임베딩은 local로 분리 권장
# LLM_EMBED_PROVIDER=local

# Fallback 활성화 (운영 Provider 실패 시 local로 재시도)
LLM_FALLBACK_ENABLED=true

# ── Local Provider (LM Studio) ────────────────────────────
LOCAL_BASE_URL=http://host.docker.internal:8000/v1
LOCAL_API_KEY=lm-studio
LOCAL_FAST_MODEL=google/gemma-4-e4b
LOCAL_HEAVY_MODEL=google/gemma-4-26b-a4b
LOCAL_VISION_MODEL=google/gemma-4-26b-a4b
LOCAL_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
LOCAL_BACKUP_MODEL=mistralai/mistral-7b-instruct-v0.3

# ── OpenAI Provider ───────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_HEAVY_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_BACKUP_MODEL=gpt-3.5-turbo

# ── Anthropic Provider ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_HEAVY_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_BACKUP_MODEL=claude-haiku-4-5-20251001
# 주의: Anthropic은 임베딩 미지원 → LLM_EMBED_PROVIDER=local 설정

# ── Google Gemini Provider ────────────────────────────────
GOOGLE_API_KEY=AIza...
GOOGLE_FAST_MODEL=gemini-2.0-flash
GOOGLE_HEAVY_MODEL=gemini-1.5-pro
GOOGLE_VISION_MODEL=gemini-2.0-flash
GOOGLE_EMBED_MODEL=text-embedding-004
GOOGLE_BACKUP_MODEL=gemini-1.5-flash

# ── Azure OpenAI Provider (기업 고객용) ───────────────────
AZURE_OPENAI_ENDPOINT=https://{your-resource}.openai.azure.com
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_FAST_DEPLOYMENT=gpt-4o-mini
AZURE_HEAVY_DEPLOYMENT=gpt-4o
AZURE_VISION_DEPLOYMENT=gpt-4o
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_BACKUP_DEPLOYMENT=gpt-4o-mini
