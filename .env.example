# shared-libraries — LM Studio / LLM (WSL + Docker 개발 PC)
# 복사: cp .env.example .env.local
# 상세: projects/docs/NETWORK-GUIDE.md

# WSL에서 Windows LM Studio (Serve on Local Network 필수)
LM_STUDIO_BASE_URL=http://192.168.0.12:1234/v1
LOCAL_BASE_URL=http://192.168.0.12:1234/v1

# Docker 컨테이너 내부에서는 host.docker.internal:1234 사용 (compose가 설정)
# LOCAL_BASE_URL=http://host.docker.internal:1234/v1

LLM_PROVIDER=local
LLM_FALLBACK_ENABLED=true

LOCAL_API_KEY=lm-studio
LOCAL_FAST_MODEL=google/gemma-4-e4b
LOCAL_HEAVY_MODEL=google/gemma-4-26b-a4b
